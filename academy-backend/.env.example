# Database
SPRING_DATASOURCE_URL=jdbc:postgresql://localhost:5432/academy
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password

# JWT
JWT_SECRET=your_jwt_secret_at_least_32_characters_long

# Mux Video Configuration
# Get these from https://dashboard.mux.com
MUX_TOKEN_ID=your_mux_token_id
MUX_TOKEN_SECRET=your_mux_token_secret
MUX_SIGNING_KEY_ID=your_signing_key_id
MUX_SIGNING_PRIVATE_KEY=-----BEGIN RSA PRIVATE KEY-----\nYOUR_PRIVATE_KEY_CONTENT\n-----END RSA PRIVATE KEY-----
MUX_WEBHOOK_SECRET=

# PayZone (optional for payment processing)
PAYZONE_MERCHANT_ID=
PAYZONE_API_KEY=
PAYZONE_SECRET_KEY=
