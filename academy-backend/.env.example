# ─── Database ────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=academy_db
DB_USERNAME=postgres
DB_PASSWORD=

# ─── JWT (min 32 chars / 256 bits) ──────────────────────────────────────────
# Generate: openssl rand -base64 64
JWT_SECRET=

# ─── Mail (Gmail SMTP App Password) ─────────────────────────────────────────
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
EMAIL_FROM=

# ─── Application ─────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
SPRING_PROFILES_ACTIVE=dev

# ─── File Storage ────────────────────────────────────────────────────────────
FILE_UPLOAD_DIR=./uploads
FILE_BASE_URL=http://localhost:8080

# ─── Mux (Video) ─────────────────────────────────────────────────────────────
MUX_TOKEN_ID=
MUX_TOKEN_SECRET=
MUX_SIGNING_KEY_ID=
MUX_SIGNING_PRIVATE_KEY=
MUX_WEBHOOK_SECRET=

# ─── PayZone ─────────────────────────────────────────────────────────────────
PAYZONE_API_URL=https://api.payzone.ma
PAYZONE_MERCHANT_ID=
PAYZONE_API_KEY=
PAYZONE_SECRET_KEY=
PAYZONE_CALLBACK_URL=http://localhost:8080/api/v1/payments/webhook
PAYZONE_RETURN_URL=http://localhost:3000/payment/callback

# ─── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of trusted frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ─── Bootstrap Admin ─────────────────────────────────────────────────────────
# Created once at startup if no ADMIN exists. Must be changed on first login.
# Password must be >= 12 characters.
ADMIN_EMAIL=
ADMIN_PASSWORD=
ADMIN_FULL_NAME=Administrator
